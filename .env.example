# Slack Bot OAuth Token (required)
# Create a bot at https://api.slack.com/apps and install it to your workspace
# Required scopes: channels:history, channels:read, reactions:read, users:read
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token-here

# OpenAI API Key (optional — falls back to VADER sentiment analysis if not set)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Flask secret key — used for session signing (generate a random string)
FLASK_SECRET_KEY=change-this-to-a-random-secret-string

# Optional overrides (uncomment to use)
# ANALYSIS_DAYS=7
# BURNOUT_THRESHOLD=-0.3
# MONITORED_CHANNELS=#general,#random,#engineering
# LOG_LEVEL=INFO
# DATABASE_PATH=./data/engagement.db
# REPORTS_DIR=./reports
